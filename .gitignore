__pycache__/
.joblib_cache
temp*
# vertebra_templates/meshes/*.ply are required templates and must be committed.
# The `temp*` rule above would otherwise exclude them (template_* matches temp*).
# The matching *.npz are a large (~2 GB) regenerable cache (rebuilt on first run).
!vertebra_templates/meshes/template_*.ply
vertebra_templates/meshes/*.npz

# analysis products (generated by pipeline)
**/analysis/
**/config_resolved.yml

# cloned Inria segmentation repo (created by setup.sh)
src/spinescrews/tools/inria_segmentor/vertebrae_segmentation/

# TotalSegmentator runtime data (model weights + config, created on first run)
src/spinescrews/tools/totalseg_segmentor/nnunet/
src/spinescrews/tools/totalseg_segmentor/config.json

# build artifacts
*.egg-info/

# IDE and OS artifacts
.idea/
.DS_Store

# per-machine Claude Code settings
**/.claude/settings.local.json

# compiled python
*.pyc

# research papers
*.pdf
